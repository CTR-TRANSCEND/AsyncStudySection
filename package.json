{
  "name": "asynchronousgrantreview2",
  "version": "1.0.0",
  "description": "A secure web-based grant review discussion system with anonymous peer review capabilities.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "true",
    "test:playwright": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:ui:headed": "playwright test --ui --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:report": "playwright show-report",
    "test:install": "playwright install chromium",
    "test:js": "vitest run",
    "test:js:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/windysky/transcend_grant_review.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/windysky/transcend_grant_review/issues"
  },
  "homepage": "https://github.com/windysky/transcend_grant_review#readme",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "jsdom": "^26.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "vitest": "^3.0.0"
  }
}
